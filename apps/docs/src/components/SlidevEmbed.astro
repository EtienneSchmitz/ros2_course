---
interface Props {
  name: string;
  title?: string;
  pdf?: boolean;
  ratio?: string;
}

const { name, title, pdf = true, ratio = "16 / 9" } = Astro.props;
const slidesUrl = `/slides/${name}/index.html`;
const pdfUrl = `/slides/${name}.pdf`;
---

<figure class="slidev-embed">
  <div class="slidev-embed__frame" style={`--ratio: ${ratio}`}>
    <iframe
      src={slidesUrl}
      title={title ?? `Slides ${name}`}
      loading="lazy"
      allow="fullscreen"
      allowfullscreen
    ></iframe>
  </div>
  <figcaption class="slidev-embed__actions">
    {title && <span class="slidev-embed__title">{title}</span>}
    <span class="slidev-embed__links">
      <a href={slidesUrl} target="_blank" rel="noopener">Plein écran ↗</a>
      {pdf && (
        <a href={pdfUrl} download>
          PDF ↓
        </a>
      )}
    </span>
  </figcaption>
</figure>

<style>
  .slidev-embed {
    margin: 1.5rem 0;
    border: 1px solid var(--bc-border, var(--sl-color-gray-5));
    border-radius: var(--bc-radius-md, 8px);
    overflow: hidden;
    background: var(--bc-bg-elevated, var(--sl-color-gray-6));
  }

  .slidev-embed__frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ratio);
    background: #000;
  }

  .slidev-embed__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .slidev-embed__actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: var(--bc-text-muted, var(--sl-color-gray-2));
  }

  .slidev-embed__title {
    font-family: var(--bc-font-display, inherit);
    font-weight: 600;
    color: var(--bc-text, var(--sl-color-white));
  }

  .slidev-embed__links {
    display: flex;
    gap: 1rem;
  }

  .slidev-embed__links a {
    color: var(--bc-accent, var(--sl-color-accent-high));
    text-decoration: none;
  }

  .slidev-embed__links a:hover {
    color: var(--bc-industrial, var(--sl-color-accent));
    text-decoration: underline;
  }
</style>
