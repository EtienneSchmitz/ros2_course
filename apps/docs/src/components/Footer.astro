---
import Default from "@astrojs/starlight/components/Footer.astro";
---

<Default><slot /></Default>

<p class="bc-credit">
  Cours conçu et animé par
  <a href="https://github.com/EtienneSchmitz" target="_blank" rel="noopener noreferrer">
    <strong>Etienne Schmitz</strong>
  </a>
</p>

<style>
  .bc-credit {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
    text-align: center;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .bc-credit strong {
    color: var(--sl-color-white);
  }
</style>
